    .geo-source-badge {
        font-size: 0.68rem;
        background: #c7d2fe;
        color: #4338ca;
        padding: 1px 7px;
        border-radius: 8px;
        font-weight: 600;
    }

    @media (max-width: 768px) {
        .geo-banner {
            padding: 6px 12px;
            gap: 8px;
            font-size: 0.78rem;
        }
        .geo-radius-control {
            padding: 3px 10px;
        }
    }
</style>
