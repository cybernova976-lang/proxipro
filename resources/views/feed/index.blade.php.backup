    }

    .geo-banner-text {
        font-weight: 500;
        display: flex;
        align-items: center;
        gap: 6px;
    }

    .geo-banner-city {
        font-weight: 700;
        color: #312e81;
    }

    .geo-radius-control {
        display: flex;
        align-items: center;
        gap: 8px;
        background: white;
        border-radius: 20px;
        padding: 4px 14px;
        border: 1px solid #c7d2fe;
        box-shadow: 0 1px 2px rgba(0,0,0,0.04);
    }

    .geo-radius-control label {
        font-size: 0.78rem;
        color: #6366f1;
        font-weight: 600;
        margin: 0;
        white-space: nowrap;
    }

    .geo-radius-select {
        border: none;
