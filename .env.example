APP_NAME=ProxiPro
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://your-app.up.railway.app

APP_LOCALE=fr
APP_FALLBACK_LOCALE=fr
APP_FAKER_LOCALE=fr_FR

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=error

# -----------------------------------------------------------------------
# DATABASE CONFIGURATION
# -----------------------------------------------------------------------
# Local development: use SQLite (no extra setup required)
#   DB_CONNECTION=sqlite
#
# Railway / production: use PostgreSQL
#   1. Add a PostgreSQL service to your Railway project
#   2. Link it to this web service
#   3. Set the variables below (Railway provides them automatically)
# -----------------------------------------------------------------------
DB_CONNECTION=pgsql
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=proxipro
DB_USERNAME=root
DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null
SESSION_SECURE_COOKIE=true
SESSION_SAME_SITE=lax

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=public
QUEUE_CONNECTION=database

CACHE_STORE=file

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=smtp
MAIL_HOST=smtp-relay.brevo.com
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM_ADDRESS=
MAIL_FROM_NAME="${APP_NAME}"

# Cloudflare R2 (compatible S3 API) — pour le stockage persistant des fichiers
# Sur Railway, définir FILESYSTEM_DISK=s3.
# En local, conserver FILESYSTEM_DISK=public.
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=auto
AWS_BUCKET=proxipro
AWS_ENDPOINT=https://<ACCOUNT_ID>.r2.cloudflarestorage.com
AWS_URL=https://pub-<CUSTOM>.r2.dev
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# Stripe
# Tant que le projet n'est pas finalise et que l'entite legale n'est pas prete,
# utilisez uniquement des cles Stripe de test (prefixes pk_test_ / sk_test_).
# Ne mettez pas de cles live ici.
STRIPE_KEY=pk_test_xxxxxxxxxxxxxxxxxxxxx
STRIPE_SECRET=sk_test_xxxxxxxxxxxxxxxxxxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxxxxxx
MARKETPLACE_COMMISSION_PERCENT=10
MARKETPLACE_CURRENCY=eur

# Admin Principal
PRINCIPAL_ADMIN_EMAIL=hardali.soudj@gmail.com
ADMIN_PASSWORD=

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=${APP_URL}/auth/google/callback

# Facebook OAuth
FACEBOOK_CLIENT_ID=
FACEBOOK_CLIENT_SECRET=

# Google reCAPTCHA v3
RECAPTCHA_SITE_KEY=
RECAPTCHA_SECRET_KEY=
RECAPTCHA_MIN_SCORE=0.5

# Coordonnées publiques (laisser vide pour masquer l'information)
SUPPORT_EMAIL=
CONTACT_PHONE=
CONTACT_LOCATION=
SUPPORT_RESPONSE_TIME="24 à 48 heures ouvrées"
SOCIAL_FACEBOOK_URL=
SOCIAL_INSTAGRAM_URL=
SOCIAL_LINKEDIN_URL=
SOCIAL_YOUTUBE_URL=

# Informations légales obligatoires à compléter avant la mise en production
LEGAL_ENTITY_NAME=
LEGAL_ENTITY_FORM=
LEGAL_REGISTRATION_NUMBER=
LEGAL_VAT_NUMBER=
LEGAL_ADDRESS=
LEGAL_PUBLICATION_DIRECTOR=
LEGAL_HOST_NAME=
LEGAL_HOST_ADDRESS=
PRIVACY_CONTACT_EMAIL=
LEGAL_LAST_UPDATED=
